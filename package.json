{
  "name": "smartpick",
  "version": "0.8.7",
  "description": "Smart text selection toolbar for Obsidian",
  "author": "BCS",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "lint:store": "eslint src/",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "toolbar",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.0",
    "eslint": "^9.39.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^16.5.0",
    "obsidian": "^1.13.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
